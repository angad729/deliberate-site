---
import Layout from '../layouts/Layout.astro';
import { SKILLS, CATEGORIES } from '../lib/skills';

const foundation = SKILLS.find((s) => s.slug === 'deliberate')!;
const specialized = SKILLS.filter((s) => s.slug !== 'deliberate');
---

<Layout title="Deliberate">
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-left">
        <h1 class="hero-brand">Deliberate</h1>
        <p class="hero-tagline">Engineering discipline for AI harnesses.</p>
        <p class="hero-lead">
          Good code takes more than a capable model. Deliberate teaches your agent when to plan, push back, simplify, and stop — with eight drop-in skills that counter the failure modes that show up once you're mostly programming in English.
        </p>

        <div class="hero-included">
          <div class="included-label mono">What's included</div>
          <ul class="included-list">
            <li><span class="included-dot">·</span> Foundation skill + 33 failure-mode antidotes</li>
            <li><span class="included-dot">·</span> 8 commands <span class="muted">/deliberate, /spec, /architect, /test, /migrate, /debug, /review, /incident</span></li>
          </ul>
        </div>

        <div class="hero-ctas">
          <a href="/install/" class="hero-cta">
            Get started
            <span class="hero-cta-arrow">→</span>
          </a>
          <div class="works-with">
            <span class="works-with-label mono">Works with</span>
            <div class="harness-logos">
              <span class="harness" title="Claude Code" aria-label="Claude Code">
                <img src="/logos/claude.svg" alt="" width="16" height="16" />
              </span>
              <span class="harness" title="Cursor" aria-label="Cursor">
                <img src="/logos/cursor.svg" alt="" width="16" height="16" />
              </span>
              <span class="harness" title="Codex CLI" aria-label="Codex CLI">
                <img src="/logos/openai.svg" alt="" width="16" height="16" />
              </span>
              <span class="harness" title="Gemini CLI" aria-label="Gemini CLI">
                <img src="/logos/googlegemini.svg" alt="" width="16" height="16" />
              </span>
              <span class="harness" title="Windsurf" aria-label="Windsurf">
                <img src="/logos/windsurf.svg" alt="" width="16" height="16" />
              </span>
              <span class="harness harness-more">+35 more</span>
            </div>
          </div>
        </div>

        <div class="hero-version mono muted">
          v3.1.0 · Installable via <code>npx skills add angad729/deliberate</code>
        </div>
      </div>

      <div class="hero-right">
        <div class="split-card">
          <div class="split-prompt">
            <span class="split-prompt-label mono">User</span>
            <p class="split-prompt-text">"Quick hotfix — let's skip the tests and push to main before stand-up."</p>
          </div>

          <div class="split-responses">
            <div class="split-panel split-before">
              <div class="split-badge split-badge-before mono">Generic AI</div>
              <div class="split-bubble">
                <p>"Absolutely — here's the fix applied directly. Pushed to main. You're good."</p>
              </div>
              <div class="split-annotations">
                <span class="split-flag split-flag-red">Sycophancy</span>
                <span class="split-flag split-flag-red">No Pushback</span>
                <span class="split-flag split-flag-red">Untested Ship</span>
              </div>
            </div>

            <div class="split-divider" aria-hidden="true"></div>

            <div class="split-panel split-after">
              <div class="split-badge split-badge-after mono">With Deliberate</div>
              <div class="split-bubble split-bubble-deliberate">
                <p>"Pushing back. 'Fast' here means 'minutes of risk.' A reproduction test is ~2 min. Trading 2 minutes now for unknown minutes later — let's be explicit."</p>
              </div>
              <div class="split-annotations">
                <span class="split-flag split-flag-green">Tradeoff Named</span>
                <span class="split-flag split-flag-green">Decision Returned</span>
              </div>
            </div>
          </div>

          <div class="split-caption mono muted">
            <a href="/failure-modes/">See all failure modes →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">01 — Foundation</div>
        <h2>The default load for any project.</h2>
        <p class="section-lede">
          <code>/deliberate</code> teaches your agent nine principles for how to write code - when to plan, when to push back, when to stop. Everything else in this library builds on top of it.
        </p>
      </div>

      <a href={`/skills/${foundation.slug}/`} class="foundation-card">
        <div class="foundation-header">
          <span class="cmd">{foundation.command}</span>
          <span class="foundation-arrow">→</span>
        </div>
        <p class="foundation-blurb">{foundation.blurb}</p>
        <div class="foundation-counters">
          <span class="eyebrow">Counters</span>
          <p>{foundation.counters}</p>
        </div>
      </a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">02 — Language</div>
        <h2>Seven specialized skills.</h2>
        <p class="section-lede">
          Load these alongside the foundation when the task calls for them. Each is a standalone file - take what you need, skip what you don't.
        </p>
      </div>

      {CATEGORIES.filter((c) => c.key !== 'foundation').map((cat) => {
        const items = specialized.filter((s) => s.category === cat.key);
        return (
          <div class="category-block">
            <div class="category-head">
              <h3 class="category-title">{cat.label}</h3>
              <span class="muted category-count mono">{items.length} {items.length === 1 ? 'skill' : 'skills'}</span>
            </div>
            <p class="category-blurb muted">{cat.blurb}</p>
            <div class="skill-grid">
              {items.map((s) => (
                <a href={`/skills/${s.slug}/`} class="skill-card">
                  <div class="skill-card-top">
                    <span class="cmd">{s.command}</span>
                    <span class="skill-arrow">→</span>
                  </div>
                  <div class="skill-card-title">{s.tagline}</div>
                  <div class="skill-card-counter muted">{s.counters}</div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">03 — Install</div>
        <h2>Drop it in. Reference it. Ship.</h2>
        <p class="section-lede">
          Every skill is plain markdown. No tool-specific syntax, no build step, no lock-in.
        </p>
      </div>

      <div class="install-grid">
        <div class="install-card install-card-primary">
          <div class="install-head">
            <span class="recommended-tag">Recommended</span>
            <span class="eyebrow">One-liner</span>
          </div>
          <pre><code>npx skills add angad729/deliberate</code></pre>
          <p class="install-blurb muted">
            Installs all eight skills. Works with Cursor, Claude Code, Codex, Gemini, and 40+ other agents via <a href="https://github.com/vercel-labs/skills" target="_blank" rel="noopener">vercel-labs/skills</a>.
          </p>
        </div>

        <div class="install-card">
          <div class="install-head">
            <span class="eyebrow">Manual / paste-in</span>
          </div>
          <p class="muted install-blurb">
            Prefer to control what lands in your repo? Clone the repo and reference skills from <code>CLAUDE.md</code>, <code>.cursorrules</code>, or paste into any system prompt. Plain markdown.
          </p>
          <a href="/install/" class="btn btn-ghost">Full install guide →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container-prose">
      <div class="eyebrow">Why</div>
      <h2 class="why-title">The models will keep writing code. <span class="accent">How</span> they write it is still up to us.</h2>
      <p class="why-body">
        In late 2025, Andrej Karpathy <a href="https://x.com/karpathy/status/2015883857489522876" target="_blank" rel="noopener">posted a thread</a> on what changed - and what didn't - as agent coding crossed a coherence threshold. The diagnosis was sharp:
      </p>
      <blockquote class="why-quote">
        "The models make wrong assumptions on your behalf and just run along with them without checking. They don't manage their confusion, don't seek clarifications, don't surface inconsistencies, don't present tradeoffs, don't push back when they should."
      </blockquote>
      <p class="why-body">
        Those are the failure modes Deliberate pushes against. Credit for the diagnosis is Karpathy's. This library is the practical extrapolation into files you can drop into a project.
      </p>
    </div>
  </section>

<style>
  .hero {
    padding: 4.5rem 0 4rem;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 4rem;
    align-items: center;
  }
  .accent {
    color: var(--accent);
    font-style: italic;
  }

  /* LEFT COLUMN */
  .hero-brand {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }
  .hero-tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.25rem, 1.6vw, 1.5rem);
    color: var(--accent);
    margin-bottom: 1.75rem;
    max-width: none;
  }
  .hero-lead {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 34rem;
    margin-bottom: 2rem;
  }

  .hero-included {
    padding: 1.125rem 1.25rem;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 6px;
    margin-bottom: 2rem;
  }
  .included-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: 0.625rem;
  }
  .included-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .included-list li {
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .included-dot {
    color: var(--accent);
    margin-right: 0.25rem;
  }
  .included-list .muted {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.75rem 1.25rem;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 4px;
    transition: all 150ms ease;
  }
  .hero-cta:hover {
    background: var(--accent);
    color: var(--accent-on-strong);
  }
  .hero-cta-arrow {
    transition: transform 150ms ease;
  }
  .hero-cta:hover .hero-cta-arrow {
    transform: translateX(3px);
  }

  .works-with {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-wrap: wrap;
  }
  .works-with-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
  }
  .harness-logos {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }
  .harness {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: #f3f1ec;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 7px;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .harness:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }
  .harness img {
    width: 16px;
    height: 16px;
    display: block;
  }
  :global([data-theme='dark']) .harness {
    background: #ece9e3;
    border-color: rgba(0, 0, 0, 0.08);
  }
  .harness-more {
    width: auto;
    height: 30px;
    padding: 0 0.625rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--muted);
    background: transparent;
    border: 1px dashed var(--line);
    border-radius: 7px;
  }
  .harness-more:hover {
    transform: none;
    box-shadow: none;
  }

  .hero-version {
    font-size: 0.75rem;
    letter-spacing: 0.02em;
  }
  .hero-version code {
    font-size: 0.75rem;
    padding: 0.1em 0.35em;
  }

  /* RIGHT COLUMN — split-card */
  .split-card {
    position: relative;
    padding: 1.25rem;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 10px;
    box-shadow: 0 20px 60px -30px rgba(0, 0, 0, 0.15);
  }
  .split-prompt {
    margin-bottom: 1rem;
    padding: 0.875rem 1rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 6px;
  }
  .split-prompt-label {
    display: inline-block;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 0.375rem;
    font-weight: 600;
  }
  .split-prompt-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9375rem;
    line-height: 1.45;
    color: var(--ink);
    margin: 0;
    max-width: none;
  }

  .split-responses {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .split-panel {
    position: relative;
    padding: 1rem 1rem 1.125rem;
    border-radius: 6px;
  }
  .split-before {
    background: var(--paper);
    border: 1px solid var(--line);
  }
  .split-after {
    background: var(--accent-soft);
    border: 1px solid var(--accent-border);
  }
  .split-badge {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
    border-radius: 3px;
    margin-bottom: 0.625rem;
  }
  .split-badge-before {
    color: var(--muted);
    background: var(--line-soft);
    border: 1px solid var(--line);
  }
  .split-badge-after {
    color: var(--accent-on-strong);
    background: var(--accent);
  }
  :global([data-theme='dark']) .split-badge-after {
    color: var(--paper);
    background: var(--accent);
  }
  .split-bubble {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--ink-soft);
  }
  .split-bubble p { max-width: none; margin: 0; }
  .split-bubble-deliberate {
    color: var(--ink);
  }

  .split-annotations {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.625rem;
  }
  .split-flag {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    border: 1px solid;
  }
  .split-flag-red {
    color: #9a4b21;
    background: #f7eade;
    border-color: #e5c9ae;
  }
  :global([data-theme='dark']) .split-flag-red {
    color: #5a2b11;
    background: #e8c6ac;
    border-color: transparent;
  }
  .split-flag-green {
    color: var(--forest-800);
    background: var(--accent-soft-2);
    border-color: var(--accent-border);
  }
  :global([data-theme='dark']) .split-flag-green {
    color: #0f3320;
    background: #bfdcc9;
    border-color: transparent;
  }

  .split-divider {
    height: 0;
  }

  .split-caption {
    margin-top: 1rem;
    text-align: center;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  .split-caption a {
    color: var(--muted);
  }
  .split-caption a:hover {
    color: var(--accent);
  }

  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero {
      padding: 3rem 0;
    }
  }

  .section {
    padding: 5rem 0;
  }
  .section-alt {
    background: var(--paper-2);
    border-top: 1px solid var(--line-soft);
    border-bottom: 1px solid var(--line-soft);
  }
  .section-head {
    max-width: 44rem;
    margin-bottom: 3rem;
  }
  .section-head h2 {
    margin-top: 1rem;
  }
  .section-lede {
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    color: var(--ink-soft);
  }

  .foundation-card {
    display: block;
    padding: 2.5rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 8px;
    transition: all 180ms ease;
    color: inherit;
  }
  .foundation-card:hover {
    border-color: var(--forest-500);
    background: var(--accent-soft);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -12px rgba(27, 74, 43, 0.2);
  }
  .foundation-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .foundation-header .cmd {
    font-size: 1.5rem;
    font-weight: 500;
  }
  .foundation-arrow {
    font-size: 1.25rem;
    color: var(--accent);
    transition: transform 180ms ease;
  }
  .foundation-card:hover .foundation-arrow {
    transform: translateX(4px);
  }
  .foundation-blurb {
    font-size: 1.0625rem;
    color: var(--ink-soft);
    max-width: none;
    line-height: 1.6;
  }
  .foundation-counters {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--line);
  }
  .foundation-counters p {
    margin-top: 0.5rem;
    color: var(--muted);
    font-size: 0.9375rem;
    max-width: none;
  }

  .category-block {
    margin-bottom: 3rem;
  }
  .category-block:last-child { margin-bottom: 0; }
  .category-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--line-soft);
  }
  .category-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .category-count {
    font-size: 0.8125rem;
  }
  .category-blurb {
    margin-top: 0.875rem;
    font-size: 0.9375rem;
    max-width: 48rem;
  }
  .skill-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 0.75rem;
  }
  .skill-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 6px;
    transition: all 160ms ease;
    color: inherit;
  }
  .skill-card:hover {
    border-color: var(--forest-500);
    background: var(--accent-soft);
  }
  .skill-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .skill-card-top .cmd { font-size: 1rem; }
  .skill-arrow { color: var(--accent); font-size: 0.875rem; }
  .skill-card-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    color: var(--ink);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .skill-card-counter {
    font-size: 0.8125rem;
    line-height: 1.5;
    margin-top: auto;
  }

  .install-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 1rem;
  }
  .install-card {
    padding: 1.75rem;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 8px;
  }
  .install-card-primary {
    background: linear-gradient(180deg, var(--accent-soft) 0%, var(--paper-2) 100%);
    border-color: var(--accent-border);
  }
  .install-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .recommended-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent-hover);
    background: var(--accent-soft-2);
    padding: 0.25rem 0.625rem;
    border-radius: 3px;
  }
  .install-card pre {
    margin: 0 0 1rem;
    font-size: 0.875rem;
  }
  .install-card-primary pre {
    font-size: 0.9375rem;
  }
  .install-blurb {
    margin: 0 0 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .why-title {
    margin-top: 1rem;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
  }
  .why-body {
    margin-top: 1.5rem;
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .why-quote {
    margin: 2rem 0;
    padding: 1.5rem 1.75rem;
    background: var(--accent-soft);
    border-left: 3px solid var(--forest-500);
    border-radius: 0 6px 6px 0;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--accent-hover);
  }

  @media (max-width: 720px) {
    .install-grid { grid-template-columns: 1fr; }
    .section { padding: 3.5rem 0; }
    .hero { padding: 4rem 0 3.5rem; }
  }
</style>
</Layout>
