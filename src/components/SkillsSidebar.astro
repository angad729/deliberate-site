---
import { SKILLS, CATEGORIES } from '../lib/skills';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  activeSlug?: string;
  headings?: Heading[];
}

const { activeSlug, headings = [] } = Astro.props;

// Only show ## (depth 2) headings in the TOC
const tocHeadings = headings.filter((h) => h.depth === 2);
---

<aside class="skills-sidebar">
  <div class="sidebar-inner">
    {CATEGORIES.map((cat) => {
      const items = SKILLS.filter((s) => s.category === cat.key);
      if (items.length === 0) return null;
      return (
        <div class="sb-group">
          <div class="sb-group-label">{cat.label}</div>
          <ul class="sb-list">
            {items.map((s) => {
              const isActive = s.slug === activeSlug;
              return (
                <li class:list={['sb-item', isActive && 'sb-item-active']}>
                  <a href={`/skills/${s.slug}/`} class="sb-link">
                    <span class="sb-cmd">{s.command}</span>
                  </a>
                  {isActive && tocHeadings.length > 0 && (
                    <ul class="sb-toc">
                      {tocHeadings.map((h) => (
                        <li class="sb-toc-item">
                          <a href={`#${h.slug}`} class="sb-toc-link">{h.text}</a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      );
    })}
  </div>
</aside>

<style>
  .skills-sidebar {
    position: sticky;
    top: 4rem;
    align-self: start;
    height: calc(100vh - 4rem);
    overflow-y: auto;
    padding: 2rem 1rem 3rem 0;
    border-right: 1px solid var(--line-soft);
    font-size: 0.875rem;
  }
  .sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sb-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .sb-group-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    padding: 0 0.625rem;
    margin-bottom: 0.125rem;
  }
  .sb-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .sb-item {
    margin: 0;
  }

  .sb-link {
    display: block;
    padding: 0.4rem 0.625rem;
    border-radius: 4px;
    color: var(--ink-soft);
    transition: all 120ms ease;
  }
  .sb-link:hover {
    color: var(--accent);
    background: var(--accent-soft);
  }
  .sb-cmd {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
  }
  .sb-item-active .sb-link {
    color: var(--accent);
    background: var(--accent-soft);
    font-weight: 600;
  }
  .sb-item-active .sb-cmd {
    font-weight: 600;
  }

  .sb-toc {
    list-style: none;
    margin: 0.375rem 0 0.5rem 1.25rem;
    padding: 0.25rem 0 0.25rem 0.625rem;
    border-left: 1px solid var(--accent-border);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .sb-toc-item { margin: 0; }
  .sb-toc-link {
    display: block;
    padding: 0.25rem 0.5rem;
    color: var(--muted);
    font-size: 0.8125rem;
    line-height: 1.4;
    border-radius: 3px;
    transition: all 120ms ease;
  }
  .sb-toc-link:hover {
    color: var(--accent);
    background: var(--accent-soft);
  }

  /* Scrollbar styling */
  .skills-sidebar::-webkit-scrollbar {
    width: 6px;
  }
  .skills-sidebar::-webkit-scrollbar-track {
    background: transparent;
  }
  .skills-sidebar::-webkit-scrollbar-thumb {
    background: var(--line);
    border-radius: 3px;
  }
  .skills-sidebar::-webkit-scrollbar-thumb:hover {
    background: var(--muted);
  }

  @media (max-width: 900px) {
    .skills-sidebar {
      position: static;
      height: auto;
      border-right: none;
      border-bottom: 1px solid var(--line-soft);
      padding: 1.5rem 0;
    }
    .sb-toc { display: none; }
  }
</style>
